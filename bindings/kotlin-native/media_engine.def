# Kotlin/Native cinterop definition for media-engine's C API.
#
# Consumers point Gradle's cinterop extension at this file, then supply
# the `-I<include>` / `-L<lib>` paths for the engine build they want to
# link against. Paths are NOT hardcoded — see ./example/build.gradle.kts
# for a working invocation that walks from the example project up to
# the repo root (../../../include, ../../../build).
#
# Generated Kotlin package:
#   io.mediaengine.cinterop
#
# Umbrella header `media_engine.h` pulls in every public sub-header
# (types / engine / timeline / render / probe / thumbnail / cache).
# `headerFilter` lets cinterop follow those includes without stepping
# into system headers.

headers = media_engine.h
headerFilter = media_engine.h media_engine/*

package = io.mediaengine.cinterop

# Link line. The cinterop tool searches `-L` paths supplied via Gradle
# `compilerOpts` / `extraOpts("-libraryPath", ...)` — we only name the
# library here so the .def stays portable.
linkerOpts.osx          = -lmedia_engine
linkerOpts.linux_x64    = -lmedia_engine
linkerOpts.linux_arm64  = -lmedia_engine
linkerOpts.ios_arm64    = -lmedia_engine
linkerOpts.ios_simulator_arm64 = -lmedia_engine
